generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  MEMBER
}

enum CleaningStatus {
  PENDING
  DONE
  SKIPPED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Mess {
  id             String   @id @default(cuid())
  name           String
  inviteCode     String   @unique
  washroomCount  Int      @default(0)
  createdById    String
  createdBy      User     @relation("MessCreator", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members           User[]             @relation("MessMembers")
  mealEntries       MealEntry[]
  deposits          Deposit[]
  bazarTrips        BazarTrip[]
  washroomDuties    WashroomCleaning[]
  managerRotations  ManagerRotation[]
  auditLogs         AuditLog[]
  disputes          Dispute[]
  joinRequests      JoinRequest[]
  mealPlans         MealPlan[]
  mealOffRequests   MealOffRequest[]
}

model User {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String   @unique
  password    String
  role        Role     @default(MEMBER)
  isActive    Boolean  @default(true)
  messId      String?
  mess        Mess?    @relation("MessMembers", fields: [messId], references: [id])
  joinDate    DateTime @default(now())
  leaveDate   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdMesses     Mess[]             @relation("MessCreator")
  mealEntries       MealEntry[]
  deposits          Deposit[]
  bazarTrips        BazarTrip[]
  washroomDuties    WashroomCleaning[]
  managerRotations  ManagerRotation[]
  auditLogs         AuditLog[]         @relation("EditedBy")
  disputes          Dispute[]
  joinRequests      JoinRequest[]
  mealOffRequests   MealOffRequest[]

  @@index([messId])
}

model MealEntry {
  id        String   @id @default(cuid())
  date      DateTime
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
  breakfast Float    @default(0)
  lunch     Float    @default(0)
  dinner    Float    @default(0)
  total     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, memberId])
  @@index([date])
  @@index([memberId])
  @@index([messId])
}

model Deposit {
  id        String   @id @default(cuid())
  date      DateTime
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
  amount    Float
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([memberId])
  @@index([messId])
}

model BazarTrip {
  id        String      @id @default(cuid())
  date      DateTime
  buyerId   String
  buyer     User        @relation(fields: [buyerId], references: [id])
  messId    String
  mess      Mess        @relation(fields: [messId], references: [id])
  totalCost Float       @default(0)
  note      String?
  items     BazarItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([date])
  @@index([messId])
}

model BazarItem {
  id        String    @id @default(cuid())
  tripId    String
  trip      BazarTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  serialNo  Int
  itemName  String
  quantity  Float
  unit      String
  price     Float     @default(0)
  createdAt DateTime  @default(now())
}

model WashroomCleaning {
  id             String         @id @default(cuid())
  date           DateTime
  washroomNumber Int            @default(1)
  memberId       String
  member         User           @relation(fields: [memberId], references: [id])
  messId         String
  mess            Mess           @relation(fields: [messId], references: [id])
  status         CleaningStatus @default(PENDING)
  note           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([date, washroomNumber, messId])
  @@index([date])
  @@index([messId])
}

model ManagerRotation {
  id        String   @id @default(cuid())
  memberId  String
  member    User     @relation(fields: [memberId], references: [id])
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
  month     Int
  year      Int
  createdAt DateTime @default(now())

  @@unique([month, year, messId])
}

model AuditLog {
  id         String   @id @default(cuid())
  editedById String
  editedBy   User     @relation("EditedBy", fields: [editedById], references: [id])
  messId     String
  mess       Mess     @relation(fields: [messId], references: [id])
  tableName  String
  recordId   String
  fieldName  String
  oldValue   String?
  newValue   String?
  action     String
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([tableName])
  @@index([messId])
}

model Dispute {
  id         String   @id @default(cuid())
  memberId   String
  member     User     @relation(fields: [memberId], references: [id])
  messId     String
  mess       Mess     @relation(fields: [messId], references: [id])
  tableName  String
  recordId   String
  message    String
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([messId])
}

model JoinRequest {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id])
  messId     String
  mess       Mess              @relation(fields: [messId], references: [id])
  status     JoinRequestStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([userId, messId])
  @@index([messId, status])
}

enum MealOffStatus {
  PENDING
  APPROVED
  REJECTED
}

model MealPlan {
  id        String   @id @default(cuid())
  date      DateTime
  messId    String
  mess      Mess     @relation(fields: [messId], references: [id])
  breakfast String?
  lunch     String?
  dinner    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, messId])
  @@index([messId])
  @@index([date])
}

model MealOffRequest {
  id        String        @id @default(cuid())
  memberId  String
  member    User          @relation(fields: [memberId], references: [id])
  messId    String
  mess      Mess          @relation(fields: [messId], references: [id])
  fromDate  DateTime
  toDate    DateTime
  reason    String?
  status    MealOffStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([messId])
  @@index([memberId])
  @@index([fromDate, toDate])
}
